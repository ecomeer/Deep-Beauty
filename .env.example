# ──────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ──────────────────────────────────────────────
# Payment — UPayments UInterfaceV2
# ──────────────────────────────────────────────
UPAYMENTS_API_TOKEN=your_upayments_bearer_token_here
UPAYMENTS_API_URL=https://sandboxapi.upayments.com/api/v1
# Optional. Leave empty for Non-Whitelabel hosted checkout.
# For Whitelabel, use one of: knet, cc, samsung-pay, apple-pay, apple-pay-knet, google-pay
UPAYMENTS_PAYMENT_GATEWAY_SRC=

# ──────────────────────────────────────────────
# Legacy payment providers (not used by the current checkout flow)
# ──────────────────────────────────────────────
MYFATOORAH_TOKEN=your_myfatoorah_token_here
MYFATOORAH_API_URL=https://apitest.myfatoorah.com/v2
TAP_SECRET_KEY=your_tap_secret_key_here

# ──────────────────────────────────────────────
# App
# ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ──────────────────────────────────────────────
# Admin Access
# Comma separated list of admin emails allowed to enter /admin
# ──────────────────────────────────────────────
ADMIN_EMAILS=admin@yourdomain.com,owner@yourdomain.com
# Optional single admin email fallback:
ADMIN_EMAIL=admin@yourdomain.com

# ──────────────────────────────────────────────
# Push Notifications (optional)
# Generate keys: npx web-push generate-vapid-keys
# ──────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com
